// VibeGuard Jenkins CI template
// Generated by 'vibeguard init-ci --jenkins' — add this to your Jenkinsfile

pipeline {
  agent {
    docker { image 'node:22' }
  }
  stages {
    stage('Install') {
      steps {
        sh 'npm ci'
      }
    }
    stage('VibeGuard Security Scan') {
      steps {
        sh 'npx -y vibeguard scan . --sarif > vibeguard-report.sarif || true'
        sh 'npx -y vibeguard scan . --fail-on high'
      }
      post {
        always {
          archiveArtifacts artifacts: 'vibeguard-report.sarif', allowEmptyArchive: true
        }
      }
    }
  }
}
